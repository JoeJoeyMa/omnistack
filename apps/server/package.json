{
  "name": "@maple-global/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:local",
    "dev:local": "wrangler dev src/index.ts --host 0.0.0.0 --port 3001 --env local",
    "dev:dev": "wrangler dev src/index.ts --host 0.0.0.0 --port 3001",
    "build": "wrangler deploy --dry-run --env=",
    "deploy": "wrangler deploy --env=",
    "secrets:sync": "node ./scripts/sync-cloudflare-secrets.mjs",
    "check-types": "tsc --noEmit",
    "lint": "biome check src drizzle.config.ts package.json tsconfig.json wrangler.jsonc .dev.vars.example",
    "db:generate": "drizzle-kit generate",
    "db:push": "pnpm run db:push:local",
    "db:push:local": "wrangler d1 migrations apply DB --local --env local",
    "db:push:dev": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@maple-global/api-client": "workspace:*",
    "@maple-global/i18n": "workspace:*",
    "@orpc/server": "1.13.6",
    "better-auth": "1.5.5",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@cloudflare/workers-types": "4.20260312.1",
    "@types/node": "25.4.0",
    "drizzle-kit": "0.31.9",
    "typescript": "5.9.3",
    "wrangler": "4.72.0"
  }
}
