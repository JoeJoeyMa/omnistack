{
  "name": "MAPLE-GLOBAL-template",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "turbo dev --filter=@maple-global/web",
    "dev:shop": "turbo dev --filter=@maple-global/shop",
    "dev:server": "turbo dev --filter=@maple-global/server",
    "dev:config": "turbo dev --filter=@maple-global/config-ui",
    "dev:native": "turbo dev --filter=@maple-global/native",
    "build": "turbo build",
    "deploy:web": "pnpm --filter @maple-global/web run deploy",
    "deploy:server": "pnpm --filter @maple-global/server run deploy",
    "deploy:server:prepare": "pnpm --filter @maple-global/server run secrets:sync && pnpm --filter @maple-global/server run db:push:dev",
    "deploy:cloudflare": "node ./scripts/deploy-cloudflare.mjs",
    "check-types": "turbo check-types",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @maple-global/server db:generate",
    "db:push": "pnpm --filter @maple-global/server db:push",
    "db:push:local": "pnpm --filter @maple-global/server db:push:local",
    "db:push:dev": "pnpm --filter @maple-global/server db:push:dev",
    "db:studio": "pnpm --filter @maple-global/server db:studio"
  },
  "devDependencies": {
    "turbo": "2.8.16",
    "typescript": "5.9.3"
  }
}
