# Local browser clients opened from another device should stay on same-origin /rpc.
# Keep this pointed at the local server only for direct dev-machine access.
VITE_SERVER_URL=http://127.0.0.1:3001
# Optional for remote/dev deployments. When omitted, shop falls back to the local web URL.
VITE_WEB_URL=https://maple-global-web.joejoey.workers.dev
