{
  "name": "@MAPLE-GLOBAL/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview --port 3000",
    "check-types": "tsc --noEmit",
    "lint": "biome check src/routes src/components src/lib src/router.tsx package.json tsconfig.json vite.config.ts wrangler.jsonc .env.example",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@MAPLE-GLOBAL/api-client": "workspace:*",
    "@MAPLE-GLOBAL/i18n": "workspace:*",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.166.7",
    "@tanstack/react-router-devtools": "1.166.7",
    "@tanstack/react-start": "1.166.8",
    "better-auth": "1.5.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@cloudflare/vite-plugin": "1.27.0",
    "@tailwindcss/vite": "4.2.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "wrangler": "4.72.0"
  }
